VITE_GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CLIENT_ID=your_github_client_id
VITE_GITHUB_REDIRECT_URI=https://awesome-astron-workflow.dev/api/github/callback
MONGODB_URI=your_mongodb_connection_string
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
VITE_SUPABASE_IMAGE_BUCKET=activity-images
VITE_ADMIN_PASSWORD=your_admin_password
ASTRON_MAAS_API_KEY=your_astron_maas_api_key
ASTRON_MAAS_MODEL=astron-code-latest
ASTRON_MAAS_BASE_URL=https://maas-coding-api.cn-huabei-1.xf-yun.com/v2/chat/completions
ASTRON_MAAS_MAX_TOKENS=32768
ASTRON_MAAS_TEMPERATURE=0.7

# Protects the Vercel cron endpoints (e.g. /api/github/warm-snapshots).
# Vercel sends this automatically as a Bearer token on scheduled invocations.
CRON_SECRET=your_cron_secret

# KB index storage (private Supabase bucket). Defaults shown; only override if
# you renamed the bucket/object. Used by scripts/{fetch,upload}-kb-index.js.
KB_STORAGE_BUCKET=kb
KB_STORAGE_PATH=kb-index.json
